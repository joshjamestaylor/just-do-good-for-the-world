# Base URL of the CMS JSON API (the Laravel + Filament backend).
#   Integrated / local dev:  http://localhost:8000/api/v1
#   Detached / production:   https://cms.example.com/api/v1
# In SSR/dev this is read at runtime; for `nuxt generate` it is baked in at build time.
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Cosmetic flag only — the data path is identical in both modes.
# 'integrated' | 'detached'
NUXT_PUBLIC_SITE_MODE=detached
